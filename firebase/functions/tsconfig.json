{
  "compilerOptions": {
    "module": "NodeNext",
    "esModuleInterop": true,
    "moduleResolution": "nodenext",
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "outDir": "lib",
    "rootDir": "src",
    "sourceMap": true,
    "strict": true,
    "target": "es2017",
    "paths": {
      "@middlewares/*": ["./src/midlewares/*"],
      "@shared/*": ["./src/shared/*"]
    }
  },
  "compileOnSave": true,
  "include": ["src"]
}
