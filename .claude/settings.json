{
  "permissions": {
    "allow": [
      "Bash(npx tsc --noEmit *)",
      "Bash(npx eslint *)",
      "Bash(graphify query *)",
      "Bash(npm run lint *)",
      "Bash(graphify explain *)",
      "Bash(graphify path *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/cristianfava/.local/bin/graphify hook-guard search"
          }
        ]
      },
      {
        "matcher": "Read|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/cristianfava/.local/bin/graphify hook-guard read"
          }
        ]
      }
    ]
  }
}